# Site credentials for digital twin login (embedded at build time for static export).
# Defaults when unset: admin@admin.com / 1234567890
NEXT_PUBLIC_SITE_EMAIL=admin@admin.com
NEXT_PUBLIC_SITE_PASSWORD=1234567890

# Set to true when Cloudflare Access protects the deployment (see docs/CLOUDFLARE_ACCESS.md)
# NEXT_PUBLIC_DISABLE_AUTH_GATE=true
